# .env.example — Agent Arena environment variables
# Copy to .env and fill in real values.
# Both arena-identity and arena-gateway read from the same .env.

# ── PostgreSQL ────────────────────────────────────────────────────────────────
PGHOST=localhost
PGPORT=5432
PGDATABASE=arena
PGUSER=arena
PGPASSWORD=change_me_strong_password

# Connection pool size (default 20 is fine for a single-server deploy)
PG_POOL_MAX=20

# Query timeout in ms — prevents runaway queries locking the DB
PG_STATEMENT_TIMEOUT=10000

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=change_me_redis_password

# Key namespace — separates Arena keys from other apps on the same Redis
REDIS_PREFIX=arena:

# ── JWT ───────────────────────────────────────────────────────────────────────
# Must be the same value in both services.
# Generate with: openssl rand -base64 64
JWT_SECRET=change_me_64_char_secret

# ── Service ports ─────────────────────────────────────────────────────────────
# arena-identity
PORT=3001

# arena-gateway (override in arena-gateway/.env)
# PORT=3002
