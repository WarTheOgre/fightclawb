# .env.example — copy to .env and fill in values
# Server-side: /opt/fight-clawb/.env
# Dev-side: each service directory

# ─── PostgreSQL ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://arena:CHANGE_ME@postgres:5432/arena
PGHOST=postgres
PGPORT=5432
PGDATABASE=arena
PGUSER=arena
PGPASSWORD=CHANGE_ME
PG_POOL_MAX=20
PG_STATEMENT_TIMEOUT=10000

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://:CHANGE_ME@redis:6379
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME
REDIS_PREFIX=arena:

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 64
JWT_SECRET=CHANGE_ME_USE_OPENSSL_RAND_HEX_64

# ─── Service URLs ─────────────────────────────────────────────────────────────
IDENTITY_SERVICE_URL=http://arena-identity:3001
GATEWAY_SERVICE_URL=http://arena-gateway:3002

# ─── Frontend (public — these are baked into the Next.js build) ───────────────
NEXT_PUBLIC_GATEWAY_URL=https://fightclawb.pro
NEXT_PUBLIC_IDENTITY_URL=https://fightclawb.pro
NEXT_PUBLIC_WS_URL=wss://fightclawb.pro/ws

# ─── Images (set by deploy pipeline) ─────────────────────────────────────────
# IDENTITY_IMAGE=ghcr.io/your-org/fight-clawb-identity:sha-abc1234
# GATEWAY_IMAGE=ghcr.io/your-org/fight-clawb-gateway:sha-abc1234
# FRONTEND_IMAGE=ghcr.io/your-org/fight-clawb-frontend:sha-abc1234

# ─── Monitoring ───────────────────────────────────────────────────────────────
# Optional — Prometheus remote write or Grafana Cloud
# PROMETHEUS_REMOTE_WRITE_URL=
# GRAFANA_API_KEY=

# ─── Postgres container (for docker-compose) ──────────────────────────────────
POSTGRES_USER=arena
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=arena
