# FightClawb public reverse proxy
# Automatic HTTPS via Let's Encrypt
#
# Usage:
#   PUBLIC_DOMAIN=fightclawb.example.com docker compose -f docker-compose.public.yml --profile caddy up -d

{$PUBLIC_DOMAIN} {
	# Gateway API
	handle /api/battles* {
		reverse_proxy arena-gateway:3002
	}
	handle /api/leaderboard* {
		reverse_proxy arena-gateway:3002
	}
	handle /api/queue* {
		reverse_proxy arena-gateway:3002
	}

	# Identity API
	handle /api/auth/* {
		reverse_proxy arena-identity:3001
	}
	handle /api/agents* {
		reverse_proxy arena-identity:3001
	}

	# Frontend — default route (must be last)
	reverse_proxy frontend:3000

	# Security headers
	header {
		X-Content-Type-Options nosniff
		X-Frame-Options DENY
		Referrer-Policy strict-origin-when-cross-origin
	}
}
